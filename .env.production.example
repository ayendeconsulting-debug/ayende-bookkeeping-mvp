# ══════════════════════════════════════════════════════════════════
# AYENDE CX — Railway Production Environment Variables
# Add ALL of these in Railway Dashboard → your service → Variables
# Railway auto-injects: DATABASE_URL, REDIS_URL, PORT
# ══════════════════════════════════════════════════════════════════

# ── Automatically set by Railway plugins (DO NOT set manually) ────
# DATABASE_URL=postgresql://...   ← set by Railway Postgres plugin
# REDIS_URL=redis://...           ← set by Railway Redis plugin
# PORT=...                        ← set by Railway automatically

# ── Plaid (copy from dashboard.plaid.com) ─────────────────────────
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_sandbox_or_production_secret
PLAID_ENV=sandbox
# Change to 'production' when going live:
# PLAID_ENV=production

# ── Encryption (CRITICAL — never lose this key) ───────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# ── AI (copy from console.anthropic.com) ──────────────────────────
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# ── App ───────────────────────────────────────────────────────────
NODE_ENV=production
# Set this once your Phase 4 frontend is deployed:
# FRONTEND_URL=https://your-frontend.railway.app
