# ─── DATABASE ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
DB_NAME=ayende_bookkeeping_multitenant

# ─── REDIS (required for BullMQ job queues) ───────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── PLAID ────────────────────────────────────────────────────────────────────
# Get these from: https://dashboard.plaid.com/developers/keys
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret

# Environment: sandbox | development | production
PLAID_ENV=sandbox

# Public URL Plaid will POST webhook events to
# Must be HTTPS in production. Use ngrok for local dev:
#   ngrok http 3000  → copy the https URL
PLAID_WEBHOOK_URL=https://your-domain.com/plaid/webhook

# Products to request (comma-separated)
PLAID_PRODUCTS=transactions

# Countries to support
PLAID_COUNTRY_CODES=US,CA

# ─── ENCRYPTION ───────────────────────────────────────────────────────────────
# AES-256 key for encrypting Plaid access_tokens at rest
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# KEEP THIS SECRET — losing it means you cannot decrypt stored tokens
ENCRYPTION_KEY=your_64_char_hex_key_here

# ─── APP ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
